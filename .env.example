# Receipt OCR System - Environment Variables Example
# Copy this file to .env and fill in your actual values

# ============================================
# OCR CONFIGURATION
# ============================================
OCR_SPACE_API_KEY=your-ocr-space-api-key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
GOOGLE_VISION_API_KEY=your-google-vision-api-key

# Document AI Configuration
DOCUMENT_AI_ENABLED=true
DOCUMENT_AI_PROJECT_ID=your-project-id
DOCUMENT_AI_PROCESSOR_ID=your-processor-id
DOCUMENT_AI_LOCATION=us

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# Performance Optimizations
OCR_ENGINE_TIMEOUT_SECONDS=12
OPENAI_CONNECT_TIMEOUT=5
OPENAI_READ_TIMEOUT=15
OPENAI_RETRY_ATTEMPTS=2

# Debug Mode
DEBUG_DRAFTS=false

# ============================================
# MICROSOFT GRAPH API CONFIGURATION (Phase 9A)
# ============================================
# Azure AD App Registration credentials
# See docs/PHASE_9A1_AZURE_AD_CHECKLIST.md for setup instructions

# Tenant ID: Found in Azure Portal > Azure AD > App Registrations > Your App > Overview
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_TENANT_ID=your-tenant-id-here

# Client ID: Found in Azure Portal > Azure AD > App Registrations > Your App > Overview  
# Format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MICROSOFT_CLIENT_ID=your-client-id-here

# Client Secret: Created in Azure Portal > App Registrations > Certificates & secrets
# ⚠️ Copy the "Value" column, not the "Secret ID"
# This is only shown once when created - save it immediately
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# User ID: Email or Object ID of the OneDrive user who owns the Excel files
# Option A: Email address (e.g., finance@yourcompany.com)
# Option B: Azure AD Object ID (GUID format)
MICROSOFT_USER_ID=your-onedrive-user-email-or-id

# OneDrive folder path where Excel files will be stored
# This folder will be created automatically if it doesn't exist
# Use forward slashes for nested folders: ReceiptOCR/2026/February
ONEDRIVE_BASE_FOLDER=ReceiptOCR
